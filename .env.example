# Copier vers .env et renseigner les valeurs.
# Port HTTP (ex. 3000, 3002)
PORT=3000

# MongoDB
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/arenaofcoders"

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Front (CORS, plusieurs origines séparées par des virgules)
FRONTEND_URL=http://localhost:3001

# File d’attente scoring asynchrone + Bull Board sur GET /queues
QUEUE_SCORING_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
