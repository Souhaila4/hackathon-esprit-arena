# Copier vers .env (ou .env.local pour surcharger).
#
# ─── Railway (deux services séparés) ─────────────────────────────────
# Backend API : https://hackathon-esprit-arena-production.up.railway.app
# Frontend site : https://hackathon-esprit-arena-production-b898.up.railway.app
# Sur le service FRONT uniquement : NEXT_PUBLIC_API_URL + API_URL = URL du backend (ligne suivante).
# Optionnel sur Railway : RAILWAY_BACKEND_PUBLIC_URL (surcharge l’URL Nest par défaut dans le code).

# Développement local (Nest sur le port 3000)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:3000

# Production (service frontend Railway) — décommenter et adapter si besoin
# NEXT_PUBLIC_API_URL=https://hackathon-esprit-arena-production.up.railway.app
# API_URL=https://hackathon-esprit-arena-production.up.railway.app
